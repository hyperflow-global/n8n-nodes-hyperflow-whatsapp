{
  "name": "@hyperflow-global/n8n-nodes-hyperflow-whatsapp",
  "version": "1.0.2",
  "description": "n8n community node for Hyperflow WhatsApp API integration",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "whatsapp",
    "hyperflow",
    "whatsapp-business",
    "messaging"
  ],
  "license": "MIT",
  "homepage": "https://github.com/hyperflow-global/n8n-nodes-hyperflow-whatsapp",
  "author": {
    "name": "Hyperflow",
    "email": "faleconosco@hyperflow.global"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hyperflow-global/n8n-nodes-hyperflow-whatsapp.git"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && gulp build:icons && gulp build:nodeJson",
    "dev": "tsc --watch",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint src --ext .ts",
    "lintfix": "eslint src --ext .ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/HyperflowWhatsAppAccount.credentials.js"
    ],
    "nodes": [
      "dist/nodes/HyperflowWhatsApp/HyperflowWhatsApp.node.js",
      "dist/nodes/HyperflowWhatsApp/HyperflowWhatsAppTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "n8n-workflow": "^1.70.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
